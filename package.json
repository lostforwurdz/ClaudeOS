{
  "name": "claudeos",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf out desktop/build runtime/out",
    "dev": "npm run desktop:dev",
    "desktop:clean": "rm -rf desktop/out desktop/build",
    "desktop:install": "npm install --prefix desktop",
    "desktop:dev": "node scripts/rebuild-natives.mjs electron && npm --prefix desktop run dev",
    "desktop:test": "npm --prefix desktop run test",
    "desktop:typecheck": "npm --prefix desktop run typecheck",
    "desktop:rebuild-natives": "node scripts/rebuild-natives.mjs electron",
    "desktop:e2e": "node scripts/rebuild-natives.mjs electron && npm --prefix desktop run build && npm --prefix desktop run e2e",
    "rebuild-natives:node": "node scripts/rebuild-natives.mjs node",
    "rebuild-natives:electron": "node scripts/rebuild-natives.mjs electron",
    "harness:install": "npm install --prefix runtime/harness",
    "harness:build": "npm --prefix runtime/harness run build",
    "harness:test": "npm --prefix runtime/harness run test",
    "harness:typecheck": "npm --prefix runtime/harness run typecheck",
    "api-server:install": "npm install --prefix runtime/api-server",
    "api-server:build": "npm --prefix runtime/api-server run build",
    "api-server:test": "node scripts/rebuild-natives.mjs node && npm --prefix runtime/api-server run test",
    "api-server:typecheck": "npm --prefix runtime/api-server run typecheck",
    "bridge:install": "bun install --cwd sdk/bridge",
    "bridge:build": "bun --cwd sdk/bridge run build",
    "bridge:test": "bun --cwd sdk/bridge run test",
    "bridge:typecheck": "bun --cwd sdk/bridge run typecheck",
    "runtime-client:install": "npm install --prefix sdk/runtime-client",
    "runtime-client:build": "npm --prefix sdk/runtime-client run build",
    "runtime-client:typecheck": "npm --prefix sdk/runtime-client run typecheck",
    "browser-mcp:install": "npm install --prefix packages/browser-mcp",
    "browser-mcp:build": "npm --prefix packages/browser-mcp run build",
    "browser-mcp:test": "npm --prefix packages/browser-mcp run test",
    "browser-mcp:typecheck": "npm --prefix packages/browser-mcp run typecheck",
    "memory-mcp:install": "npm install --prefix packages/memory-mcp",
    "memory-mcp:build": "npm --prefix packages/memory-mcp run build",
    "memory-mcp:test": "npm --prefix packages/memory-mcp run test",
    "memory-mcp:typecheck": "npm --prefix packages/memory-mcp run typecheck",
    "runtime:test": "npm run harness:test && npm run api-server:test && npm run browser-mcp:test && npm run memory-mcp:test",
    "runtime:typecheck": "npm run harness:typecheck && npm run api-server:typecheck && npm run browser-mcp:typecheck && npm run memory-mcp:typecheck"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "ws": "^8.20.0"
  }
}
